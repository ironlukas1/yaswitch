#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BIN_PATH="$SCRIPT_DIR/target/release/yaswitch"

if [[ ! -x "$BIN_PATH" ]]; then
  echo "Building yaswitch release binary..." >&2
  cargo build --release --manifest-path "$SCRIPT_DIR/Cargo.toml" >&2
fi

exec "$BIN_PATH" "$@"
